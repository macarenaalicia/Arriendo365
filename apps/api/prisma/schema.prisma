generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------- ENUMS ----------

enum RolUsuario {
  ADMINISTRADOR
  PROPIETARIO
  ARRENDATARIO
  TECNICO
}

enum TipoPropiedad {
  CASA
  DEPARTAMENTO
  HABITACION
  TERRENO
}

enum EstadoPropiedad {
  DISPONIBLE
  ARRENDADA
  EN_MANTENCION
  USUFRUCTO
}

enum TipoProveedor {
  AGUA
  LUZ
  GAS
}

enum EstadoProveedor {
  ACTIVO
  INACTIVO
}

enum EstadoArriendo {
  ACTIVO
  INACTIVO
  TERMINADO
}

enum EstadoPago {
  PENDIENTE
  PAGADO
  ATRASADO
  RECHAZADO
}

enum CategoriaPago {
  ARRIENDO
  SERVICIOS_BASICOS
  // Depósito de garantía de un arriendo de auto (no es un pago periódico).
  GARANTIA
}

enum UrgenciaRequerimiento {
  CRITICA
  MEDIA
  BAJA
}

enum EstadoRequerimiento {
  PENDIENTE_REVISION
  REVISION_AGENDADA
  EN_REVISION
  RESUELTO
  RECHAZADO
  REABIERTO
}

enum TipoReparacion {
  ESTRUCTURAL
  LOCATIVA
}

enum QuienPago {
  PROPIETARIO
  ARRENDATARIO
}

enum EstadoAuto {
  DISPONIBLE
  ARRENDADO
  EN_MANTENCION
}

enum TipoDocumentoAuto {
  PERMISO_CIRCULACION
  REVISION_TECNICA
  SOAP
}

enum EstadoDocumentoAuto {
  ACTIVO
  VENCIDO
}

enum Periodicidad {
  MENSUAL
  TRIMESTRAL
  SEMESTRAL
  ANUAL
}

// Cada cuánto se paga el arriendo de un auto (a diferencia de propiedades,
// que siempre es mensual con un día fijo del mes).
enum PeriodoPagoAuto {
  SEMANAL
  DOS_SEMANAS
  MENSUAL
}

enum TipoPagoVehiculo {
  SEGURO
  TAG
  REVISION_TECNICA
  PERMISO_CIRCULACION
  SOAP
  MULTA
}

enum TipoCobroAuto {
  TAG
  ARRIENDO
  REPARACION
  DEVOLUCION
}

// ---------- TENANT ----------

model Organizacion {
  id        String   @id @default(uuid())
  nombre    String
  plan      String?
  activo    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  usuarios    Usuario[]
  personas    Persona[]
  propiedades Propiedad[]
  autos       Auto[]

  @@map("organizacion")
}

model Usuario {
  id             String       @id @default(uuid())
  organizacionId String
  organizacion   Organizacion @relation(fields: [organizacionId], references: [id])
  personaId      String
  persona        Persona      @relation(fields: [personaId], references: [id])
  rol            RolUsuario
  passwordHash   String
  activo         Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  actualizacionesRequerimiento RequerimientoActualizacion[]

  @@map("usuario")
}

// ---------- PERSONA (entidad transversal) ----------

model Persona {
  id                    String       @id @default(uuid())
  organizacionId        String
  organizacion          Organizacion @relation(fields: [organizacionId], references: [id])
  nombreCompleto        String
  // Un técnico (tipoPersona TECNICO) solo exige nombre completo: no se le
  // pide RUT ni el resto de los datos legales que sí necesita un
  // arrendatario/codeudor.
  rut                   String?
  // Categoriza a la persona (ej. técnico, arrendatario) independiente de si
  // tiene o no un Usuario con acceso a la plataforma — un técnico no
  // necesita login para poder ser asignado a un requerimiento.
  tipoPersona           RolUsuario?
  fechaNacimiento       DateTime?
  direccion             String?
  telefono              String?
  email                 String?
  dicom360DocId         String?
  carnetFrontalFotoId   String?
  carnetTraseraFotoId   String?
  licenciaFrontalFotoId String?
  licenciaTraseraFotoId String?
  contratoTrabajoDocId  String?
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt

  recomendaciones         PersonaRecomendacion[]
  usuarios                Usuario[]
  arriendosPropiedad      ArriendoPropiedad[]          @relation("ArrendatarioPropiedad")
  codeudorDe              ArriendoPropiedad[]          @relation("CodeudorPropiedad")
  arriendosAuto           ArriendoAuto[]
  requerimientosAsignados Requerimiento[]
  requerimientoHistorial  RequerimientoActualizacion[]
  mensajes                ChatMensaje[]

  @@unique([organizacionId, rut])
  @@map("persona")
}

model PersonaRecomendacion {
  id             String  @id @default(uuid())
  personaId      String
  persona        Persona @relation(fields: [personaId], references: [id])
  nombreCompleto String
  numeroContacto String

  @@map("persona_recomendacion")
}

// ---------- DOCUMENTO / FOTO (transversales, polimórficas) ----------
// entidadTipo + entidadId se validan a nivel de aplicación (Prisma no soporta
// FK polimórfica nativa). Ver nota en brief_claude_code.md.

model Documento {
  id               String    @id @default(uuid())
  tipo             String
  archivoUrl       String
  fechaEmision     DateTime?
  fechaVencimiento DateTime?
  entidadTipo      String
  entidadId        String
  createdAt        DateTime  @default(now())

  @@index([entidadTipo, entidadId])
  @@map("documento")
}

model Foto {
  id          String   @id @default(uuid())
  archivoUrl  String
  descripcion String?
  categoria   String?
  entidadTipo String
  entidadId   String
  createdAt   DateTime @default(now())

  @@index([entidadTipo, entidadId])
  @@map("foto")
}

// ---------- PROPIEDADES ----------

model Propiedad {
  id                     String          @id @default(uuid())
  organizacionId         String
  organizacion           Organizacion    @relation(fields: [organizacionId], references: [id])
  rol                    String
  calle                  String
  numero                 String
  numeroDepartamento     String?
  sector                 String?
  ciudad                 String
  region                 String
  tipo                   TipoPropiedad
  nHabitaciones          Int
  nBanos                 Int
  bodega                 Boolean         @default(false)
  bodegaNumero           String?
  estacionamiento        Boolean         @default(false)
  estacionamientoNumero  String?
  mt2Totales             Decimal         @db.Decimal(8, 2)
  mt2Construidos         Decimal         @db.Decimal(8, 2)
  descripcion            String?
  estado                 EstadoPropiedad @default(DISPONIBLE)
  pagaContribuciones     Boolean         @default(false)
  // Precio de referencia para publicar la propiedad en la vista pública
  // mientras está DISPONIBLE (no es el monto de un contrato de arriendo).
  precioArriendoEsperado Decimal?        @db.Decimal(10, 2)
  createdAt              DateTime        @default(now())
  updatedAt              DateTime        @updatedAt

  proveedores Proveedor[]
  arriendos   ArriendoPropiedad[]

  @@map("propiedad")
}

model Proveedor {
  id          String          @id @default(uuid())
  propiedadId String
  propiedad   Propiedad       @relation(fields: [propiedadId], references: [id])
  tipo        TipoProveedor
  empresa     String          @default("")
  nCliente    String
  estado      EstadoProveedor @default(ACTIVO)

  @@map("proveedor")
}

// ---------- ARRIENDO DE PROPIEDAD (entidad raíz del sistema) ----------

model ArriendoPropiedad {
  id                      String         @id @default(uuid())
  propiedadId             String
  propiedad               Propiedad      @relation(fields: [propiedadId], references: [id])
  arrendatarioId          String
  arrendatario            Persona        @relation("ArrendatarioPropiedad", fields: [arrendatarioId], references: [id])
  codeudorId              String?
  codeudor                Persona?       @relation("CodeudorPropiedad", fields: [codeudorId], references: [id])
  fechaPago               Int
  fechaEntrega            DateTime
  fechaRecepcion          DateTime?
  periodoAlza             String
  garantia                Boolean        @default(false)
  garantiaMontoPactado    Decimal?       @db.Decimal(10, 2)
  garantiaMontoPagado     Decimal?       @db.Decimal(10, 2)
  garantiaFechaDevolucion DateTime?
  garantiaMontoDevuelto   Decimal?       @db.Decimal(10, 2)
  garantiaMotivoRetencion String?
  montoArriendo           Decimal        @db.Decimal(10, 2)
  actaEntregaDetalle      String?
  actaRecepcionDetalle    String?
  estado                  EstadoArriendo @default(ACTIVO)
  createdAt               DateTime       @default(now())
  updatedAt               DateTime       @updatedAt

  inventario     ArriendoInventario[]
  requerimientos Requerimiento[]

  @@map("arriendo_propiedad")
}

model ArriendoInventario {
  id                  String            @id @default(uuid())
  arriendoPropiedadId String
  arriendoPropiedad   ArriendoPropiedad @relation(fields: [arriendoPropiedadId], references: [id])
  fotoId              String
  descripcion         String?

  @@map("arriendo_inventario")
}

// Pago es polimórfico entre ArriendoPropiedad y ArriendoAuto (arriendoTipo + arriendoId).
// Sin relación formal en Prisma por el mismo motivo que Documento/Foto: se valida en la app.
model Pago {
  id                String         @id @default(uuid())
  arriendoTipo      String // "propiedad" | "auto"
  arriendoId        String
  periodo           DateTime
  fechaComprometida DateTime
  // Solo aplica a arriendos de auto: el período de pago no es un mes fijo
  // como en propiedades, sino un rango (fechaComprometida = desde, esta =
  // hasta). Queda null para pagos de propiedad.
  periodoHasta      DateTime?
  // Solo aplica a arriendos de auto: kilometraje del auto al momento del
  // pago, cuando se informa (no siempre se registra).
  kilometraje       Int?
  fechaPagoReal     DateTime?
  monto             Decimal        @db.Decimal(10, 2)
  medioPago         String?
  esAbono           Boolean        @default(false)
  estado            EstadoPago     @default(PENDIENTE)
  categoria         CategoriaPago  @default(ARRIENDO)
  // Solo aplica cuando categoria = SERVICIOS_BASICOS; reutiliza el mismo
  // enum que Proveedor.tipo para no duplicar el listado de servicios.
  tipoServicio      TipoProveedor?
  comprobanteFotoId String?
  aprobado          Boolean?
  motivoRechazo     String?
  createdAt         DateTime       @default(now())

  @@index([arriendoTipo, arriendoId])
  @@map("pago")
}

// ---------- REQUERIMIENTOS ----------

model Requerimiento {
  id                  String                @id @default(uuid())
  arriendoPropiedadId String
  arriendoPropiedad   ArriendoPropiedad     @relation(fields: [arriendoPropiedadId], references: [id])
  urgencia            UrgenciaRequerimiento
  estado              EstadoRequerimiento   @default(PENDIENTE_REVISION)
  tecnicoId           String?
  tecnico             Persona?              @relation(fields: [tecnicoId], references: [id])
  tipoReparacion      TipoReparacion
  detalleResolucion   String?
  notasInternas       String?
  notasArrendatario   String?
  fechaComprometida   DateTime?
  fechaSolucion       DateTime?
  valorPagado         Decimal?              @db.Decimal(10, 2)
  quienPago           QuienPago?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt

  presupuestos    RequerimientoPresupuesto[]
  gastos          Gasto[]
  actualizaciones RequerimientoActualizacion[]

  @@map("requerimiento")
}

// Guarda el estado ANTERIOR del requerimiento justo antes de cada edición
// (no una descripción del cambio), para poder comparar a la vista la fila
// vigente contra sus versiones previas usando las mismas columnas.
model RequerimientoActualizacion {
  id                String                @id @default(uuid())
  requerimientoId   String
  requerimiento     Requerimiento         @relation(fields: [requerimientoId], references: [id], onDelete: Cascade)
  urgencia          UrgenciaRequerimiento
  estado            EstadoRequerimiento
  tipoReparacion    TipoReparacion
  tecnicoId         String?
  tecnico           Persona?              @relation(fields: [tecnicoId], references: [id])
  notasArrendatario String?
  detalleResolucion String?
  nota              String?
  usuarioId         String?
  usuario           Usuario?              @relation(fields: [usuarioId], references: [id])
  createdAt         DateTime              @default(now())

  @@map("requerimiento_actualizacion")
}

model RequerimientoPresupuesto {
  id              String        @id @default(uuid())
  requerimientoId String
  requerimiento   Requerimiento @relation(fields: [requerimientoId], references: [id])
  fotoId          String
  valor           Decimal       @db.Decimal(10, 2)

  @@map("requerimiento_presupuesto")
}

model Gasto {
  id              String        @id @default(uuid())
  requerimientoId String
  requerimiento   Requerimiento @relation(fields: [requerimientoId], references: [id])
  fotoBoletaId    String?
  valor           Decimal       @db.Decimal(10, 2)
  detalle         String?

  @@map("gasto")
}

// ---------- VEHÍCULOS ----------

model Auto {
  id             String       @id @default(uuid())
  organizacionId String
  organizacion   Organizacion @relation(fields: [organizacionId], references: [id])
  patente        String
  marca          String?
  modelo         String?
  anio           Int?
  kilometraje    Int
  padronDocId    String?
  estado         EstadoAuto   @default(DISPONIBLE)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  documentos    DocumentoAuto[]
  mantenciones  MantencionAuto[]
  arriendos     ArriendoAuto[]
  pagosVehiculo PagoVehiculo[]
  cobros        CobroAuto[]

  @@unique([organizacionId, patente])
  @@map("auto")
}

model DocumentoAuto {
  id               String              @id @default(uuid())
  autoId           String
  auto             Auto                @relation(fields: [autoId], references: [id])
  tipo             TipoDocumentoAuto
  fechaRealizacion DateTime
  fechaVencimiento DateTime
  estado           EstadoDocumentoAuto @default(ACTIVO)

  @@map("documento_auto")
}

model ConfiguracionMantencion {
  id     String @id @default(uuid())
  tipo   String
  cadaKm Int

  items MantencionAutoItem[]

  @@map("configuracion_mantencion")
}

model MantencionAuto {
  id                 String     @id @default(uuid())
  autoId             String
  auto               Auto       @relation(fields: [autoId], references: [id])
  kilometrajeActual  Int
  kilometrajeProxima Int?
  fechaMantencion    DateTime
  // Costo de la mantención, con el mismo flujo de revisión que los pagos de
  // arriendo (pendiente/aprobado/rechazado) — quien la registra no queda
  // aprobada automáticamente, otro staff la revisa después.
  costo              Decimal?   @db.Decimal(10, 2)
  // Quién debe hacerse cargo del costo (el medio de pago no es relevante).
  quienPago          QuienPago?
  estadoPago         EstadoPago @default(PENDIENTE)
  aprobado           Boolean?
  motivoRechazo      String?

  items MantencionAutoItem[]

  @@map("mantencion_auto")
}

// Una visita de mantención puede cubrir varios tipos a la vez
// (ej. cambio de aceite + filtro de aire en la misma visita).
model MantencionAutoItem {
  id               String                  @id @default(uuid())
  mantencionAutoId String
  mantencionAuto   MantencionAuto          @relation(fields: [mantencionAutoId], references: [id], onDelete: Cascade)
  configuracionId  String
  configuracion    ConfiguracionMantencion @relation(fields: [configuracionId], references: [id])

  @@map("mantencion_auto_item")
}

model ArriendoAuto {
  id                   String         @id @default(uuid())
  autoId               String
  auto                 Auto           @relation(fields: [autoId], references: [id])
  arrendatarioId       String
  arrendatario         Persona        @relation(fields: [arrendatarioId], references: [id])
  kilometrajeEntrega   Int
  kilometrajeRecepcion Int?
  contratoDocId        String?
  // A diferencia de ArriendoPropiedad (que usa un día fijo del mes), un
  // arriendo de auto se paga con esta frecuencia.
  periodoPago          PeriodoPagoAuto @default(MENSUAL)
  fechaEntrega         DateTime
  periodoAlza          String
  montoArriendo        Decimal        @db.Decimal(10, 2)
  estado               EstadoArriendo @default(ACTIVO)
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt

  @@map("arriendo_auto")
}

model PagoVehiculo {
  id                String           @id @default(uuid())
  autoId            String
  auto              Auto             @relation(fields: [autoId], references: [id])
  tipo              TipoPagoVehiculo
  // Solo aplica cuando tipo = TAG: a qué autopista corresponde el cobro.
  autopista         String?
  // Solo aplica cuando tipo = TAG: número de boleta del cobro.
  numeroBoleta      String?
  periodicidad      Periodicidad
  conCredito        Boolean          @default(false)
  cuotas            Int?
  montoCuota        Decimal?         @db.Decimal(10, 2)
  monto             Decimal          @db.Decimal(10, 2)
  fechaPago         DateTime
  comprobanteFotoId String?
  // Se marca en true solo cuando montoPagado alcanza el monto total de la
  // boleta (ver "Registrar abono" en el detalle del auto).
  pagado            Boolean          @default(false)
  // Cuánto se le ha abonado a esta boleta hasta ahora — un abono puede ser
  // parcial y no cubrirla completa (queda con saldo = monto - montoPagado).
  montoPagado        Decimal         @default(0) @db.Decimal(10, 2)
  // true solo en la fila que representa el abono en sí (no una boleta),
  // generada automáticamente al registrar un abono.
  esAbono           Boolean          @default(false)
  // En una boleta: a qué abono quedó asociada (si fue pagada). En la fila
  // del abono: null. Permite revertir las boletas a pendiente si se
  // elimina el abono que las cubría.
  abonoId           String?
  abono             PagoVehiculo?    @relation("AbonoBoletas", fields: [abonoId], references: [id])
  boletasCubiertas  PagoVehiculo[]   @relation("AbonoBoletas")
  // Usado por MULTA (y disponible para otros tipos a futuro): estado de
  // pago y fecha en que efectivamente se pagó, distinta de fechaPago (que
  // para una multa es la fecha de la infracción/registro).
  estado            EstadoPago       @default(PENDIENTE)
  fechaPagoReal     DateTime?

  @@map("pago_vehiculo")
}

model CobroAuto {
  id          String        @id @default(uuid())
  autoId      String
  auto        Auto          @relation(fields: [autoId], references: [id])
  tipo        TipoCobroAuto
  responsable QuienPago
  quienReparo QuienPago?
  valor       Decimal       @db.Decimal(10, 2)
  detalle     String?

  @@map("cobro_auto")
}

// ---------- COMUNICACIÓN ----------
// Polimórfico igual que Pago: arriendoTipo + arriendoId sin relación formal.

model ChatMensaje {
  id           String   @id @default(uuid())
  arriendoTipo String
  arriendoId   String
  autorId      String
  autor        Persona  @relation(fields: [autorId], references: [id])
  mensaje      String
  fecha        DateTime @default(now())

  @@index([arriendoTipo, arriendoId])
  @@map("chat_mensaje")
}
